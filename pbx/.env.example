# pbx .env.example
# General
FQDN=pbx.firma.at
PUBLIC_IP=1.2.3.4
FS_DEFAULT_PASSWORD=GENERATED

# Database (PostgreSQL)
POSTGRES_USER=telofon
POSTGRES_DB=telofon
POSTGRES_PASSWORD=GENERATED
DATABASE_URL=postgresql://telofon:GENERATED@postgres:5432/telofon

# Redis
REDIS_PASSWORD=GENERATED

# Security
JWT_SECRET=GENERATED
ADMIN_PASSWORD_HASH=GENERATED
ADMIN_SIP_PASSWORD=GENERATED

# Storage (Minio)
MINIO_ROOT_USER=pbxadmin
MINIO_ROOT_PASSWORD=GENERATED

# Networking
TURN_SECRET=GENERATED
